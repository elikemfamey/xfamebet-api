# Server
NODE_ENV=development
PORT=4000

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Redis (Upstash or self-hosted)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-minimum-32-chars

# Paystack
PAYSTACK_SECRET_KEY=your-paystack-secret-key
PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret

# URLs
FRONTEND_URL=https://xfamebet.com
API_URL=https://api.xfamebet.com

# Crypto (Company operational wallet - USDT TRC20)
CRYPTO_WALLET_ADDRESS=TXxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sports Data APIs
ODDS_API_KEY=your-odds-api-key
API_FOOTBALL_KEY=your-api-football-key
SPORTMONKS_API_TOKEN=your-sportmonks-api-token

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@xfamebet.com
SMTP_PASS=your-app-password
SMTP_FROM=XfameBet <noreply@xfamebet.com>

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
